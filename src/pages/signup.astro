---
import PrimaryLayout from "~/layouts/PrimaryLayout.astro";
import twoXl from '~/assets/footerlogo.png';
//import { createBossCustomer } from "~/lib/boss-client.ts";
import { supabase } from "~/lib/supabase.ts";

// Handle Form Submission
if (Astro.request.method === "POST") {
  try {
    const data = await Astro.request.formData();
    const firstName = data.get("firstName") as string;
    const lastName = data.get("lastName") as string;
    const email = data.get("email") as string;
    const phone = data.get("phone") as string;

    // 1. Create in Boss
     //const bossUser = await createBossCustomer({ firstName, lastName, email, phone });

    // 2. Trigger Supabase Magic Link
     await supabase.auth.signInWithOtp({ email });

    return Astro.redirect("/login?sent=true");
  } catch (e) {
    console.error(e);
  }
}
---

<PrimaryLayout title="הצטרפות לג'ונו">
  <div class="relative min-h-screen w-full flex flex-col md:flex-row overflow-hidden">
    
    <!-- THE BLUE BACKGROUND (Desktop Only) -->
    <!-- This div "breaks out" by being absolute and covering the right 50% -->
    <div class="hidden md:block absolute top-0 bottom-0 right-0 w-1/2 bg-theme-base-600 z-0"></div>

    <!-- LEFT: FORM SIDE -->
    <div class="relative z-10 flex flex-1 items-center justify-center p-8 bg-white min-h-[50vh] md:min-h-screen">
      <div class="w-full max-w-md text-center space-y-6">
          <h1 class="text-3xl font-black text-theme-base-600">הצטרפו למשפחה 🐾</h1>
          <p class="text-orange-500 mt-2">צבירת נקודות, הטבות ומעקב הזמנות</p>

        <form method="POST" class="space-y-4">
          <div class="grid grid-cols-2 gap-4">
            <input name="firstName" placeholder="שם פרטי" required class="border rounded-xl p-3 w-full" />
            <input name="lastName" placeholder="שם משפחה" required class="border rounded-xl p-3 w-full" />
          </div>
          <input type="email" name="email" placeholder="אימייל" required class="border rounded-xl p-3 w-full" />
          <input type="tel" name="phone" placeholder="טלפון" required class="border rounded-xl p-3 w-full text-right" />
          
          <button type="submit" class="w-full bg-theme-base-600 text-white font-bold rounded-xl p-4 hover:bg-opacity-90 transition">
            יצירת חשבון
          </button>
        </form>


        <p class="text-center text-sm text-gray-500">
          כבר רשומים? <a href="/login" class="text-theme-base-600 font-bold underline">התחברו כאן</a>
        </p>
      </div>
    </div>


    <!-- RIGHT: VISUAL -->
    <div class="relative z-10 hidden bg-theme-base-600 md:flex flex-1 items-center justify-center min-h-screen">
      <img src={twoXl.src} class="h-[400px] object-contain" alt="Juno Logo" />
    </div>
        <!-- MOBILE LOGO VIEW (Optional: shows blue bar on mobile top/bottom if you want) -->
    <div class="md:hidden bg-theme-base-600 p-8 flex justify-center mb-6">
       <img src={twoXl.src} class="h-32 object-contain" alt="Logo" />
    </div>
                        </div>

  </div>
</PrimaryLayout>
