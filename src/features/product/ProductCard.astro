---
import { Image } from 'astro:assets';
import type { Product } from 'storefront:client';
import { twMerge } from 'tailwind-merge';
import Card from '~/components/ui/Card.tsx';
import { formatProductPrice } from '~/lib/currency.ts';
import { productPath } from '~/paths.ts';
import { ProductPrice } from './ProductPrice.tsx';
import {TinyAddToCartForm} from '~/features/cart/TinyAddToCartForm.tsx';

interface Props extends Product {
	class?: string;
	elementId?: string | null;
	imageLoading?: 'eager' | 'lazy';
}

const { class: className, elementId, imageLoading, ...product } = Astro.props;
---

<div 
    class={twMerge(`group relative  flex flex-col w-full  shadow-md rounded-2xl p-4 bg-white`, className)} 
    id={elementId ?? undefined}
>
    {/* 1. Main Link Area - 'flex-grow' ensures this fills all vertical space */}
    <a 
        href={productPath(product.slug)} 
        class="focus-visible:ring-2 flex flex-col flex-grow mb-4"
        aria-label={`${product.name} for ${formatProductPrice(product.price)}`}
    >
        <article class="flex flex-col flex-grow">
            <Card class="flex aspect-[5/6] items-center justify-center shrink-0">
                <Image
                    src={new URL(product.imageUrl, Astro.url).href}
                    alt={product.name}
                    width={290}
                    height={290}
                    loading={imageLoading ?? 'lazy'}
                    densities={[1, 1.5, 2]}
                    draggable="false"
                />
            </Card>
            
            {/* This div holds text. flex-grow here ensures the spacing stays consistent */}
            <div class="flex flex-col gap-2 p-2 font-medium flex-grow">
<h3 class="text-pretty leading-tight text-theme-base-900 line-clamp-2 min-h-[2.5rem]">
    {product.name}
</h3>                <p class="text-lg/tight text-theme-base-600 mt-auto">
                    <ProductPrice price={product.price} discount={product.discount} />
                </p>
            </div>
        </article>

        <div class="pointer-events-none absolute inset-0 ring-inset ring-theme-base-900 group-focus-visible:ring-2 rounded-2xl"></div>
    </a>

    {/* 2. Tiny Add to Cart - Stays at the very bottom */}
    <div class="relative z-10 mt-auto">
        <TinyAddToCartForm product={product} client:load />
    </div>
</div>

