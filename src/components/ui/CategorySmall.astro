---
import Emoji from 'astro-emoji'

const { collection, href, count } = Astro.props
---

<a

href={href ?? `/collections/${collection.slug}`}

class="
md:col-span-1
border
border-theme-base-600
text-theme-base-600
rounded-2xl
p-6
flex
flex-col
items-center
text-center
hover:shadow-lg
transition
"

>
			<Emoji symbol={collection.emoji} style="font-size: 5rem;"  />.




<h2 class="h4 text-primary-500">

{collection.name}

</h2>
    <p class="opacity-60">
      {count ?? 0} מוצרים
    </p>


</a>