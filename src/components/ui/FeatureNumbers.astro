---
/**
 * * This is a section with four number cards that show some stats about the business.
 * You can update the data below to change the stats.
 */

import FeatureCardNumbers from "../ui/FeatureCardNumbers.astro";

interface FeatureCardData {
	largeText: string;
	description: string;
	subtitle: string;
}

// NOTE: You still need to manually update the heading that come before the cards
const featureData: FeatureCardData[] = [
		{
		largeText: "2,400",
		description: `מוצרים במלאי`,
		subtitle: "מזון, אביזרים, טיפוח וצעצועים — הכל מוכן לשליחה"
	},
		{
		largeText: "40+",
		description: `מותגים מובילים`,
		subtitle: "Royal Canin, Hill's, Orijen ועוד מהמובילים בעולם"
	},
		{
		largeText: "48h",
		description: "משלוח מהיר",
		subtitle: "הזמינו היום ותקבלו עד הבית עד מחרתיים"
	},
	{
		largeText: "★4.9",
		description: "דירוג לקוחות",
		subtitle: "מעל 12,000 ביקורות מלקוחות מרוצים"
	},



];
---

<section id="feature-numbers" class="breakout bg-theme-base-200">
	<div class="mx-auto max-w-6xl px-4">
						<hr class="border-theme-base-600 mt-4 mb-6 w-full border-1" />


		<div
			id="feature-numbers-cards"
			class="mt-6 grid gap-10 gap-y-16 sm:grid-cols-2 md:mt-12 lg:grid-cols-4"
		>
		
			{
				featureData.map((feature) => (
					<FeatureCardNumbers largeText={feature.largeText} description={feature.description} subtitle={feature.subtitle}/>
				))
			}
		</div>
								<hr class="border-theme-base-600 mt-4 mb-6 w-full border-1" />

	</div>
</section>
