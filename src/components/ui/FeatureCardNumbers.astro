---
/**
 * * These are cards with a large number, and description below
 */

interface Props {
	largeText: string;
	description: string;
	subtitle: string;
	rest?: any; // catch-all for any additional parameters, such as "aria-label"
}

const { largeText, description, subtitle, ...rest } = Astro.props as Props;
---

<div {...rest} class="flex flex-col gap-3 text-right">

	<h3 class="font-decorative text-primary-500 text-[4rem] leading-none">
		{largeText}
	</h3>

	<p class="description font-heading-1 pr-2 text-xl text-theme-base-600">
		{description}
	</p>
		<p class="description font-heading-1 pr-2 text-l text-theme-base-600">
		{subtitle}
	</p>
</div>
