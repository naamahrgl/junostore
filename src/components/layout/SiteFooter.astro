---
import ExternalLink from '~/components/ui/ExternalLink.astro';
import twoXl from '~/assets/footerlogo.png';
import Nav from './Nav.astro';
import { Button } from '../ui/Button.tsx';



export interface Props {
	class?: string;
}
---

<footer class={`breakout ${Astro.props.class}`} dir="ltr">
		<section class=" flex flex-row items-center justify-between  py-4 bg-theme-base-600 px-4 md:px-32">
			<div>
			<img src={twoXl.src} class="h-[420px]">
			</div>
									<div class="flex w-1/3 text-right flex-col items-end justify-end gap-4">
										
										<h4 class="text-4xl text-theme-base-200">קבלו מאיתנו את החדשות האחרונות</h4>
										<div>
										<input type="email" value="הזן את המייל שלך" class="text-theme-base-600 text-right px-2 text-2xl">
										<h4 class="text-theme-base-200">
		בהרשמה, אתה מסכים למדיניות הפרטיות ולתנאי השירות שלנו
									</h4>
								</div>
									<Button  >
										<a href="/">subscribe</a>
									</Button>
</div>

			<div class=" w-1/3 text-right break-words">
<Nav overrideClass='text-xl hover:underline text-theme-base-100 inline-block mr-4' containerClass='flex flex-col gap-4'/>
</div>

	</section>


	<section class=" flex flex-wrap w-full justify-between gap-y-2 py-6 text-sm text-theme-base-200 bg-theme-base-600 px-4 md:px-32">
				<div class=" flex flex-wrap gap-2" aria-label="Social links">

				</div>

		<p>
			{'© 2026 | '}
			<ExternalLink href="https://junopetstore.netlify.app" target="_blank" rel="noopener noreferrer">
				{'Juno'}
			</ExternalLink><span>{' | All Rights Reserved.'}</span>
			<p class="flex flex-wrap gap-x-4">
				<ExternalLink href="https://astro.build/privacy/" target="_blank" rel="noopener noreferrer">
					 מדיניות פרטיות
				</ExternalLink>
				<ExternalLink href="https://astro.build/terms/" target="_blank" rel="noopener noreferrer">
					תנאי שימוש
				</ExternalLink>
			</p>
		</p>
	</section>
</footer>