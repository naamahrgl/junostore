---
//import ExternalLink from '~/components/ui/ExternalLink.astro';
import twoXl from '~/assets/footerlogo.png';
import Nav from './Nav.astro';
import { Button } from '../ui/Button.tsx';



export interface Props {
	class?: string;
}
---

<footer class="breakout bg-theme-base-600 text-theme-base-200" >
  <section class="flex flex-col md:flex-row items-center justify-between gap-8 py-12 px-6 md:px-32">
  
    <!-- Nav Section -->
    <div class="w-full md:w-1/3">
      <Nav overrideClass="text-lg hover:underline" containerClass="flex flex-col items-center md:items-start gap-4" />
    </div>
    <!-- Newsletter Section -->
    <div class="w-full md:w-1/3 flex flex-col items-center md:items-start gap-4 text-center md:text-right">
      <h4 class="text-2xl md:text-4xl">קבלו מאיתנו את החדשות האחרונות</h4>
      <input type="email" placeholder="הזן את המייל שלך" class="w-full text-theme-base-600 px-4 py-2 text-xl rounded-lg" />
      <p class="text-xs opacity-70">בהרשמה, אתה מסכים למדיניות הפרטיות ולתנאי השירות שלנו</p>
      <Button class="w-full md:w-auto">Subscribe</Button>
    </div>
  <!-- Logo Section -->
    <div class="w-full md:w-auto flex justify-center">
      <img src={twoXl.src} class="h-48 md:h-[420px] object-contain" />
    </div>

  </section>
</footer>
